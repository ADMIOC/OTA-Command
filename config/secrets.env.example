# ============================================================
# OTA Command — Secrets Template
# Copy to secrets.env and fill in your values.
# NEVER commit secrets.env to the repo.
# For GitHub Actions, set these as repository secrets.
# ============================================================

# --- Core ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Phase 1: Discovery ---
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Phase 7: Production ---
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DESCRIPT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Phase 9: Distribution ---
RESTREAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Drive ---
GOOGLE_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json

# --- Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# --- Phase 10: Analytics ---
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=xxxxxxxxxxxxxxxx
