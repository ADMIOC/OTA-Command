# ============================================================
# OTA Command — Secrets Template
# Copy to secrets.env and fill in your values.
# NEVER commit secrets.env to the repo.
# For GitHub Actions, set these as repository secrets.
# ============================================================

# --- Core ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Phase 1: Discovery ---
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Drive (Phase 4: Storage) ---
GOOGLE_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json

# --- Notifications (Notion) ---
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Workflow Chaining ---
# PAT with repo+workflow scope for repository_dispatch between phases
PIPELINE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Phases 06-10 secrets live with their respective agents:
#   KNOCK OUT  → ANTHROPIC_API_KEY (content generation)
#   ENCORE     → ELEVENLABS_API_KEY, DESCRIPT_API_KEY, RESTREAM_API_KEY
#   FREQUENCY  → platform API keys (X, LinkedIn, etc.)
# ============================================================
